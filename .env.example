AIRTABLE_API_KEY=your_airtable_personal_access_token
AIRTABLE_BASE_ID=appbbbPs9ngSR6fIK
AIRTABLE_TABLE_NAME=Knowledge_Items
KB_PASSWORD=your_chosen_password

# ── Shopify Live Orders ───────────────────────────────────────────────────────
# Required to sync live order data from Shopify Admin API
# SHOPIFY_SHOP_URL = your .myshopify.com domain (not custom domain)
#   Find in: Shopify Admin → Settings → Store details → Store address domain
# SHOPIFY_ADMIN_TOKEN = Admin API access token from a Custom App
#   Create at: Shopify Admin → Settings → Apps → Develop apps
#   Scopes needed: read_orders, read_customers, read_products
SHOPIFY_SHOP_URL=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
